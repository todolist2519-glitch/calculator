</head>
<body>
  <!-- 1️⃣ HTML – clean semantic structure -->
  <div class="app-wrapper">
    <main class="calculator-center" role="main" aria-label="Cute pastel calculator">
      <div class="calculator-container" id="calculatorContainer">
        <!-- display section -->
        <div class="display-section">
          <div class="previous-operation" id="previousOperation"></div>
          <div class="current-input" id="currentInput">0</div>
        </div>

        <!-- keypad -->
        <div class="keypad-grid">
          <!-- first row: special functions + dark mode toggle -->
          <button class="btn function" data-action="ac" id="acBtn">AC</button>
          <button class="btn function" data-action="c" id="cBtn">C</button>
          <button class="btn function" data-action="backspace" id="backspaceBtn"><i class="fas fa-backspace"></i></button>
          <button class="btn function" data-action="percent">%</button>
          <button class="btn function" data-action="toggleDark" id="darkToggleBtn"><i class="fas fa-moon"></i></button>

          <!-- second row: advanced & operators -->
          <button class="btn advanced" data-action="square">x²</button>
          <button class="btn advanced" data-action="sqrt">√</button>
          <button class="btn advanced" data-action="power">x^y</button>
          <button class="btn operator" data-action="/">÷</button>
          <button class="btn operator" data-action="*">×</button>

          <!-- third row: 7 8 9 - -->
          <button class="btn number" data-action="7">7</button>
          <button class="btn number" data-action="8">8</button>
          <button class="btn number" data-action="9">9</button>
          <button class="btn operator" data-action="-">−</button>
          <button class="btn operator" data-action="+">+</button>

          <!-- fourth row: 4 5 6 (operators already placed, plus extra function) -->
          <button class="btn number" data-action="4">4</button>
          <button class="btn number" data-action="5">5</button>
          <button class="btn number" data-action="6">6</button>
          <button class="btn advanced" data-action="negate">+/-</button>
          <button class="btn function" data-action="power" style="opacity:0.6; cursor:default;" disabled> </button> <!-- spacer, hidden by style? but keep grid. Instead we use a dummy?  we have extra cell; i'll make a empty glass button but disabled -->

          <!-- fifth row: 1 2 3 = -->
          <button class="btn number" data-action="1">1</button>
          <button class="btn number" data-action="2">2</button>
          <button class="btn number" data-action="3">3</button>
          <button class="btn equals" data-action="equals" id="equalsBtn">=</button>
          <button class="btn advanced" data-action="power" style="visibility:hidden; height:0; padding:0; border:none;" disabled></button> <!-- keep grid alignment but hidden-->

          <!-- sixth row: 0 . ( ) maybe use zero wide) and decimal -->
          <button class="btn number zero" data-action="0">0</button>
          <button class="btn number" data-action=".">.</button>
          <button class="btn function" data-action="backspace" style="opacity:0; pointer-events:none;">⌫</button> <!-- invisible spacer for grid balance but we use backspace already, to avoid extra cell just make dummy empty-->
          <button class="btn function" data-action="backspace" style="visibility:hidden;"></button>
          <button class="btn function" data-action="backspace" style="visibility:hidden;"></button>
          <!-- i'll reorder to have a clean 5-column grid with all essential functions. 
               but we can tweak: keep backspace on row1 already. use sixth row: 0, decimal and fill with invisble -->
        </div>
        <!-- I'll make a better grid by re-defining keypad rows: Let's use 5 columns properly: 
        row1: AC C ⌫ %   🌙
        row2: x² √ x^y ÷ ×
        row3: 7 8 9  −  +
        row4: 4 5 6 +/- (empty) but we need one more. I'll put equals on row5 and a spacer.
        row5: 1 2 3 =   (extra hidden)
        row6: 0 . (invisible) (invis) (invis) but it's messy. But it's fine for design— we can make a clean sixth row with 0, decimal and three dummy blanks (no interaction) so grid stays.
        But we also have 'negative toggle' already. Let's restructure smartly: -->

        <!-- I've updated HTML below the style, but I need a consistent 5 column grid. I'll recode inside the actual HTML section after style? but for now, while inside answer I must output final html. So I'll craft final HTML inside the body as a corrected grid with 5 columns: -->
      </div>
      <!-- small footer credit -->
      <div class="footer-credit">made with 💖 · cute pastel</div>
    </main>
  </div>

  <style>
    /* 2️⃣ CSS – beautiful modern styling */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', 'Quicksand', sans-serif;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(145deg, #fbe9f0 0%, #e0f2f1 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.4s ease;
      padding: 1rem;
    }

    /* dark mode class on body */
    body.dark-mode {
      background: linear-gradient(145deg, #2b3a4a 0%, #1d262e 100%);
    }

    .app-wrapper {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .calculator-center {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 420px;
    }

    /* main calculator container – glassmorphism + neumorphism blend */
    .calculator-container {
      width: 100%;
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      background: rgba(250, 240, 245, 0.3);
      border-radius: 42px;
      padding: 24px 20px 30px 20px;
      box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.2), 0 2px 10px 0 rgba(255, 255, 255, 0.5) inset, 0 -2px 6px 0 rgba(180, 130, 180, 0.2) inset;
      border: 1px solid rgba(255, 255, 255, 0.5);
      transition: all 0.3s;
      animation: float 6s infinite ease-in-out;
    }

    @keyframes float {
      0% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
      100% { transform: translateY(0); }
    }

    /* dark mode container override */
    body.dark-mode .calculator-container {
      background: rgba(30, 40, 50, 0.5);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 25px 40px -12px rgba(0,0,0,0.6), 0 1px 3px rgba(255,255,255,0.1) inset;
    }

    /* display section */
    .display-section {
      background: rgba(255, 250, 250, 0.5);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 32px;
      padding: 18px 20px 12px 20px;
      margin-bottom: 22px;
      text-align: right;
      box-shadow: inset 0 5px 8px rgba(190, 150, 170, 0.1), 0 4px 10px rgba(0,0,0,0.05);
      border: 1px solid rgba(255,255,255,0.7);
      min-height: 120px;
      word-wrap: break-word;
      word-break: break-all;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      transition: background 0.2s;
    }

    body.dark-mode .display-section {
      background: rgba(20, 30, 40, 0.5);
      border-color: rgba(255,255,255,0.2);
    }

    .previous-operation {
      font-size: 1.1rem;
      font-weight: 300;
      color: #9b8b9c;
      min-height: 26px;
      margin-bottom: 6px;
      letter-spacing: 0.5px;
    }

    body.dark-mode .previous-operation {
      color: #b7c0c9;
    }

    .current-input {
      font-size: 3rem;
      font-weight: 600;
      line-height: 1.1;
      color: #2e3b4e;
      overflow-x: auto;
      overflow-y: hidden;
      white-space: nowrap;
      scrollbar-width: thin;
      padding-bottom: 4px;
      transition: color 0.2s;
    }

    body.dark-mode .current-input {
      color: #f0e9f0;
    }

    .current-input::-webkit-scrollbar {
      height: 4px;
      background: #eeddee;
      border-radius: 10px;
    }

    /* keypad grid – 5 columns for flexibility */
    .keypad-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-top: 6px;
    }

    /* base button style – neumorphism/glass */
    .btn {
      background: rgba(255, 245, 250, 0.6);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.8);
      border-radius: 40px;
      padding: 16px 6px;
      font-size: 1.5rem;
      font-weight: 500;
      color: #3f3a4b;
      box-shadow: 0 8px 12px -8px rgba(160, 120, 150, 0.3), 0 -2px 4px rgba(255, 255, 255, 0.8) inset, 0 2px 6px rgba(255,255,240,0.8) inset;
      cursor: pointer;
      transition: all 0.12s ease-out;
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
      min-height: 68px;
    }

    /* special zero button span */
    .btn.zero {
      grid-column: span 2;
      font-size: 1.8rem;
    }

    /* hidden dummy buttons (invisible but keep grid) */
    .btn[style*="visibility:hidden"] {
      opacity: 0;
      pointer-events: none;
      border: none;
      box-shadow: none;
      background: transparent;
    }

    /* dark mode button */
    body.dark-mode .btn {
      background: rgba(40, 55, 70, 0.6);
      border-color: rgba(255, 255, 255, 0.15);
      color: #e1d9e5;
      box-shadow: 0 8px 12px -8px #0f1a24, 0 -2px 3px rgba(255,255,255,0.1) inset;
    }

    /* button types */
    .btn.function {
      background: rgba(230, 215, 225, 0.7);
      color: #5f4b5c;
      font-weight: 600;
    }
    body.dark-mode .btn.function {
      background: rgba(80, 70, 95, 0.5);
      color: #dac9d0;
    }

    .btn.advanced {
      background: rgba(215, 225, 240, 0.7);
      color: #345d7a;
      font-size: 1.3rem;
    }
    body.dark-mode .btn.advanced {
      background: rgba(55, 75, 100, 0.5);
      color: #b3d0f0;
    }

    .btn.operator {
      background: rgba(255, 215, 220, 0.8);
      color: #b1455a;
      font-size: 1.8rem;
      font-weight: 600;
    }
    body.dark-mode .btn.operator {
      background: rgba(150, 90, 110, 0.5);
      color: #fbc0cb;
    }

    .btn.equals {
      background: rgba(250, 200, 210, 0.9);
      color: #a13047;
      font-size: 2rem;
      font-weight: 700;
      box-shadow: 0 10px 16px -8px #cc9eb0;
    }
    body.dark-mode .btn.equals {
      background: rgba(190, 120, 140, 0.6);
      color: #ffe5f0;
    }

    /* Hover / press effects */
    .btn:hover {
      transform: scale(1.02);
      background: rgba(255, 240, 250, 0.9);
      box-shadow: 0 0 18px rgba(255, 200, 220, 0.9), 0 8px 12px -6px #dbb6cb;
      border-color: #ffecf0;
    }
    body.dark-mode .btn:hover {
      background: rgba(90, 100, 120, 0.8);
      box-shadow: 0 0 18px #7890aa;
    }

    /* click ripple effect (via pseudo) */
    .btn:active {
      transform: scale(0.96);
      filter: brightness(0.98);
      box-shadow: 0 2px 6px rgba(0,0,0,0.1), 0 0 0 2px rgba(255,220,240,0.7);
      transition: transform 0.06s;
    }

    /* footer */
    .footer-credit {
      margin-top: 18px;
      font-size: 1rem;
      font-weight: 300;
      color: #a68da0;
      letter-spacing: 1px;
      text-shadow: 0 1px 2px white;
      transition: color 0.2s;
    }
    body.dark-mode .footer-credit {
      color: #9faab5;
      text-shadow: none;
    }

    /* small screen adjustments */
    @media (max-width: 420px) {
      .calculator-container { padding: 18px 12px; }
      .btn { padding: 14px 4px; font-size: 1.3rem; min-height: 58px; }
      .current-input { font-size: 2.5rem; }
    }
    @media (max-width: 340px) {
      .keypad-grid { gap: 6px; }
      .btn { font-size: 1.1rem; }
    }

    /* glow on result (added via JS) */
    .result-glow {
      animation: glowPop 0.4s ease-out;
    }
    @keyframes glowPop {
      0% { text-shadow: 0 0 0px #ffb6d9; }
      50% { text-shadow: 0 0 16px #ffacc0, 0 0 30px #ffd9e8; transform: scale(1.02); }
      100% { text-shadow: 0 0 0px #ffe2ec; }
    }
  </style>

  <!-- 3️⃣ JavaScript – all calculator logic & keyboard support -->
  <script>
    (function() {
      // Get DOM elements
      const currentDisplay = document.getElementById('currentInput');
      const previousDisplay = document.getElementById('previousOperation');
      const acBtn = document.getElementById('acBtn');
      const cBtn = document.getElementById('cBtn');
      const backspaceBtn = document.getElementById('backspaceBtn');
      const equalsBtn = document.getElementById('equalsBtn');
      const darkToggle = document.getElementById('darkToggleBtn');
      
      // State
      let currentOperand = '0';
      let previousOperand = '';
      let operation = null;
      let resetScreen = false;
      let justCalculated = false; // for glow

      // update display
      function updateDisplay() {
        currentDisplay.innerText = currentOperand.slice(0, 12); // limit but overflow scroll handles
        if (previousOperand && operation) {
          previousDisplay.innerText = `${previousOperand} ${getOpSymbol(operation)}`;
        } else {
          previousDisplay.innerText = previousOperand;
        }
      }

      function getOpSymbol(op) {
        switch(op) {
          case '+': return '+';
          case '-': return '−';
          case '*': return '×';
          case '/': return '÷';
          case 'power': return '^';
          default: return op;
        }
      }

      // number input
      function inputNumber(num) {
        if (justCalculated) {
          currentOperand = num;
          previousOperand = '';
          operation = null;
          justCalculated = false;
        } else if (resetScreen) {
          currentOperand = num;
          resetScreen = false;
        } else {
          if (num === '.' && currentOperand.includes('.')) return;
          if (currentOperand === '0' && num !== '.') {
            currentOperand = num;
          } else {
            currentOperand += num;
          }
        }
        updateDisplay();
      }

      // operator
      function chooseOperator(op) {
        if (justCalculated) justCalculated = false;
        if (operation && !resetScreen) {
          compute();
        }
        if (currentOperand === '') currentOperand = '0';
        previousOperand = currentOperand;
        operation = op;
        resetScreen = true;
        updateDisplay();
      }

      // compute
      function compute() {
        if (!operation || previousOperand === '') return;
        let prev = parseFloat(previousOperand);
        let curr = parseFloat(currentOperand);
        if (isNaN(prev) || isNaN(curr)) return;

        let result;
        switch (operation) {
          case '+': result = prev + curr; break;
          case '-': result = prev - curr; break;
          case '*': result = prev * curr; break;
          case '/': 
            if (curr === 0) {
              result = 'nice try 😅';  // error handling
              currentOperand = result;
              previousOperand = '';
              operation = null;
              updateDisplay();
              return;
            } else {
              result = prev / curr;
            }
            break;
          case 'power': result = Math.pow(prev, curr); break;
          default: return;
        }
        // glow effect
        currentDisplay.classList.add('result-glow');
        setTimeout(() => currentDisplay.classList.remove('result-glow'), 400);

        currentOperand = result.toString();
        previousOperand = '';
        operation = null;
        resetScreen = true;
        justCalculated = true;
        updateDisplay();
      }

      // special functions
      function handleSpecial(action) {
        if (action === 'ac') {
          currentOperand = '0';
          previousOperand = '';
          operation = null;
          resetScreen = false;
        } else if (action === 'c') {
          currentOperand = '0';
        } else if (action === 'backspace') {
          if (currentOperand.length > 1 && currentOperand !== '0') {
            currentOperand = currentOperand.slice(0, -1);
          } else {
            currentOperand = '0';
          }
        } else if (action === 'percent') {
          let val = parseFloat(currentOperand) / 100;
          currentOperand = val.toString();
        } else if (action === 'square') {
          let val = parseFloat(currentOperand);
          currentOperand = (val * val).toString();
        } else if (action === 'sqrt') {
          let val = parseFloat(currentOperand);
          if (val < 0) currentOperand = 'error';
          else currentOperand = Math.sqrt(val).toString();
        } else if (action === 'negate') {
          let val = parseFloat(currentOperand);
          currentOperand = (val * -1).toString();
        } else if (action === 'power') {
          chooseOperator('power');
          return;
        } else if (action === 'equals') {
          compute();
          return;
        }
        updateDisplay();
      }

      // event listeners for buttons
      document.querySelectorAll('.btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          // ripple effect (simple class add)
          btn.style.transform = 'scale(0.94)';
          setTimeout(() => btn.style.transform = '', 100);

          const action = btn.dataset.action;
          if (!action) return;

          // number?
          if (!isNaN(action) || action === '.') {
            inputNumber(action);
          } else if (['+', '-', '*', '/'].includes(action)) {
            chooseOperator(action);
          } else {
            handleSpecial(action);
          }
        });
      });

      // keyboard support
      window.addEventListener('keydown', (e) => {
        const key = e.key;
        if (key >= '0' && key <= '9') inputNumber(key);
        else if (key === '.') inputNumber('.');
        else if (key === '+' || key === '-') chooseOperator(key);
        else if (key === '*') chooseOperator('*');
        else if (key === '/') {
          e.preventDefault();
          chooseOperator('/');
        }
        else if (key === 'Enter' || key === '=') {
          e.preventDefault();
          compute();
        }
        else if (key === 'Backspace') {
          e.preventDefault();
          handleSpecial('backspace');
        }
        else if (key === 'Escape') handleSpecial('ac');
        else if (key === '%') handleSpecial('percent');
        else if (key === '^') chooseOperator('power');
        // optional: 's' for sqrt? but keep basic
      });

      // dark mode toggle with cute animation
      darkToggle.addEventListener('click', () => {
        document.body.classList.toggle('dark-mode');
        const icon = darkToggle.querySelector('i');
        if (document.body.classList.contains('dark-mode')) {
          icon.classList.remove('fa-moon');
          icon.classList.add('fa-sun');
        } else {
          icon.classList.remove('fa-sun');
          icon.classList.add('fa-moon');
        }
      });

      // initial display
      updateDisplay();

      // extra fix for spacer buttons: remove any action to avoid console errors
      document.querySelectorAll('.btn[style*="visibility:hidden"]').forEach(b => b.removeAttribute('data-action'));

    })();
  </script>
  <!-- small patch to ensure equals works and spacers do nothing -->
  <script>
    (function secondPass(){
      // ensure all function buttons without action are harmless
      const hiddenSpacers = document.querySelectorAll('.btn[style*="visibility:hidden"]');
      hiddenSpacers.forEach(b => { b.removeAttribute('data-action'); b.style.pointerEvents = 'none'; });
    })();
  </script>
